# =============================================================================
# Environment placeholder reference for this k3s infrastructure repository
# =============================================================================
# All placeholder variables used across YAML manifests, Helm values, and
# config templates are listed here with descriptions.
#
# HOW TO USE:
#   Replace every occurrence of the variable names below in the repo with
#   your actual environment values before deploying.
#   The companion file docs/variables.txt lists them as a quick reference.
#   Never commit real values — use Vault or a secrets manager instead.
# =============================================================================


# -----------------------------------------------------------------------------
# Networking
# -----------------------------------------------------------------------------

# Internal HTTP/HTTPS proxy (e.g. http://proxy.example.internal:8888)
PROXY=

# Primary external node IP — used in HAProxy and ProxySQL backends for the
# ATL/primary cluster. Replace with your actual node IP.
IP_ADDR=

# Secondary external node IP — used for hostAliases in ARC runner pods to
# resolve the private GitHub FQDN. Replace with the DNS IP of $PRIVATE_GH_FQDN.
IP_ADDR2=


# -----------------------------------------------------------------------------
# Private registries and repositories
# -----------------------------------------------------------------------------

# Hostname of the private Artifactory container registry
# (e.g. artifactory.example.internal)
ARTIFACTORY=

# Sub-path within Artifactory for your team's Docker repository
# (e.g. myteam-docker-local)
ARTIFACTORY_SUB_PATH=

# FQDN of your private GitHub Enterprise instance
# (e.g. github.example.internal)
PRIVATE_GH_FQDN=

# Any application-specific GitHub repository path on the private GHE
# (e.g. myorg/my-app-repo)
APP_SOME_GH_REPOSITORY=


# -----------------------------------------------------------------------------
# Vault / cluster FQDN
# -----------------------------------------------------------------------------

# Fully qualified domain name of the Vault server (and general cluster FQDN)
# Used in VaultConnection manifests (e.g. vault.example.internal)
FQDN=


# -----------------------------------------------------------------------------
# Cluster nodes — hostname or FQDN of each k3s node
# -----------------------------------------------------------------------------

NODE_1=
NODE_2=
NODE_3=
NODE_4=
NODE_5=
NODE_6=
# NODE_7 and NODE_8 are used as Vault peer node addresses in HA Vault setup
NODE_7=
NODE_8=


# -----------------------------------------------------------------------------
# Teams / namespaces
# -----------------------------------------------------------------------------

# Primary application team namespace (default: team1)
TEAM1=team1

# Alternate name used for team1 in certain routing or DB contexts
TEAM1_ALT=

# Second application team namespace (default: team2)
TEAM2=team2

# Third application team namespace
TEAM3=team3

# Application identifier — used as a prefix for app-specific resources
# Examples: app1, app2, app3 …
APP_ID=


# -----------------------------------------------------------------------------
# Service accounts / CI identities
# -----------------------------------------------------------------------------

# Vault path segment for the CI/CD tooling service account
# (e.g. tooling_account_id)
TOOLING_ACCOUNT_ID=tooling_account_id

# Vault path segment for the human/user service account
# (e.g. user_account_id)
USER_ACCOUNT_ID=user_account_id
